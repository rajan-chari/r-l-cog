{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -m 4 -X POST -H \"Content-Type: application/json\" -d @- http://127.0.0.1:4601/api/hook/session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:4601/api/hook/stop",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:4601/api/hook/notify",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:4601/api/hook/prompt-submit",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "messageIdleNotifThresholdMs": 5000
}